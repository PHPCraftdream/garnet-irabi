{
    "name": "phpcraftdream/app",
    "type": "project",
    "license": ["MIT", "Apache-2.0"],
    "authors": [
        {"name": "PHPCraftdream", "email": "phpcraftdream@gmail.com", "homepage": "https://github.com/PHPCraftdream"}
    ],
    "autoload": {
        "psr-4": {
            "PHPCraftdream\\IRabi\\": "./"
        }
    },
    "require": {
        "phpcraftdream/garnet-framework": "^0.1.0-alpha4",
        "zachweix/php-zmanim": "^2.0"
    },
    "scripts": {
        "setup": "@php garnet setup --skip-composer",
        "post-install-cmd": "@php garnet setup --skip-composer --soft",
        "phpstan": "phpstan analyse --configuration=phpstan.neon",
        "cs:check": "php-cs-fixer fix --dry-run --allow-risky=yes",
        "cs:fix": "php-cs-fixer fix --allow-risky=yes",
        "test:e2e": "npm --prefix Tests test",
        "build": "@php garnet build",
        "build:check": "@php garnet build:check",
        "check": [
            "@phpstan",
            "@cs:check"
        ],
        "ci": [
            "@cs:check",
            "@build",
            "@phpstan",
            "@build:check"
        ]
    },
    "require-dev": {
        "phpstan/phpstan": "2.1.38",
        "friendsofphp/php-cs-fixer": "~3.93.0"
    }
}
